{
  "$schema": "./hooks.schema.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/matt/.superset/hooks/notify.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/using-release-workflow-session.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/using-git-commit-co-author-session.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/using-git-commit-co-author-tool.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/using-release-workflow-tool.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/matt/.superset/hooks/notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/matt/.superset/hooks/notify.sh"
          }
        ]
      }
    ]
  }
}
