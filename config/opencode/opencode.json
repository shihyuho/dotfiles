{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "oh-my-opencode-slim@latest",
    "opencode-command-inject@latest"
  ],
  "default_agent": "orchestrator",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "GSD": {
      "permission": {
        "skill": {
          "brainstorming": "deny",
          "dispatching-parallel-agents": "deny",
          "executing-plans": "deny",
          "finishing-a-development-branch": "deny",
          "receiving-code-review": "deny",
          "requesting-code-review": "deny",
          "subagent-driven-development": "deny",
          "systematic-debugging": "deny",
          "test-driven-development": "deny",
          "using-git-worktrees": "deny",
          "using-superpowers": "deny",
          "verification-before-completion": "deny",
          "writing-plans": "deny"
        }
      }
    }
  },
  "mcp": {
    "start_kapok": {
      "enabled": false,
      "type": "remote",
      "url": "http://start-kapok.192.168.1.240.nip.io/mcp"
    },
    "kapok": {
      "enabled": false,
      "type": "remote",
      "url": "http://kapok.192.168.1.240.nip.io/mcp"
    },
    "markitdown": {
      "enabled": false,
      "type": "local",
      "command": [
        "markitdown-mcp"
      ]
    },
    "gh_grep": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    }
  },
  "permission": {
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "~/.config/opencode/get-shit-done/*": "allow"
    }
  },
  "lsp": {
    "jdtls": {
      "command": [
        "jdtls-lombok"
      ],
      "extensions": [
        ".java"
      ]
    }
  }
}