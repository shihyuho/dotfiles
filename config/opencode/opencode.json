{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "oh-my-opencode-slim@latest",
    "opencode-command-inject@latest"
  ],
  "default_agent": "Orchestrator",
  "model": "openai/gpt-5.4",
  "small_model": "minimax-coding-plan/MiniMax-M2.5",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "mcp": {
    "start_kapok": {
      "enabled": false,
      "type": "remote",
      "url": "http://start-kapok.192.168.1.240.nip.io/mcp"
    },
    "kapok": {
      "enabled": false,
      "type": "remote",
      "url": "http://kapok.192.168.1.240.nip.io/mcp"
    },
    "markitdown": {
      "enabled": false,
      "type": "local",
      "command": [
        "markitdown-mcp"
      ]
    },
    "gh_grep": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    }
  },
  "permission": {
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "~/.config/opencode/get-shit-done/*": "allow"
    }
  },
  "lsp": {
    "jdtls": {
      "command": [
        "/bin/sh",
        "-lc",
        "exec \"$HOME/.config/opencode/bin/start_jdtls.sh\""
      ],
      "extensions": [
        ".java"
      ]
    }
  }
}