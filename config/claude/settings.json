{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ANTHROPIC_MODEL": "opus[1m]",
    "MAX_CONSECUTIVE_AUTOCOMPACT_FAILURES": "3",
    "USE_BUILTIN_RIPGREP": "0"
  },
  "permissions": {
    "allow": [
      "Read(~/.claude/**)",
      "Read(~/code/**)",
      "Read(~/Downloads/**)",
      "Read(~/Documents/**)",
      "Read(~/tmp/**)",
      "Read(/tmp/**)"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout .:*)",
      "Bash(git restore .:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh release delete:*)",
      "Bash(gh api * -X DELETE)",
      "Bash(gh api * --method DELETE)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/using-git-commit-co-author-tool.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/using-release-workflow-tool.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/using-git-commit-co-author-session.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/using-release-workflow-session.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "jdtls-lombok-lsp@shihyuho-dotfiles": true,
    "lua-lsp@claude-plugins-official": true,
    "output-styles@shihyuho-dotfiles": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "agent-skills@addy-agent-skills": true,
    "frontend-design@claude-plugins-official": true,
    "skills@shihyuho-skills": true,
    "webwright@webwright": true,
    "warp@claude-code-warp": true,
    "engineering@softleader-agent-skills": true,
    "operations@softleader-agent-skills": true,
    "productivity@softleader-agent-skills": true,
    "misc@softleader-agent-skills": true,
    "wip@softleader-agent-skills": true,
    "deprecated@softleader-agent-skills": true,
    "pangu@pangu": true
  },
  "extraKnownMarketplaces": {
    "shihyuho-dotfiles": {
      "source": {
        "source": "github",
        "repo": "shihyuho/dotfiles"
      },
      "autoUpdate": true
    },
    "addy-agent-skills": {
      "source": {
        "source": "github",
        "repo": "addyosmani/agent-skills"
      },
      "autoUpdate": true
    },
    "shihyuho-skills": {
      "source": {
        "source": "github",
        "repo": "shihyuho/skills"
      },
      "autoUpdate": true
    },
    "webwright": {
      "source": {
        "source": "github",
        "repo": "microsoft/Webwright"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    },
    "softleader-agent-skills": {
      "source": {
        "source": "github",
        "repo": "softleader/agent-skills"
      },
      "autoUpdate": true
    },
    "pangu": {
      "source": {
        "source": "github",
        "repo": "shihyuho/pangu.skill"
      }
    }
  },
  "outputStyle": "default",
  "language": "Traditional Chinese (zh_TW)",
  "effortLevel": "xhigh",
  "ultracode": true,
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "viewMode": "verbose",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
