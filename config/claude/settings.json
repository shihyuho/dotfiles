{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ANTHROPIC_MODEL": "opus[1m]",
    "MAX_CONSECUTIVE_AUTOCOMPACT_FAILURES": "3",
    "USE_BUILTIN_RIPGREP": "0"
  },
  "permissions": {
    "allow": [
      "Read(~/.claude/**)",
      "Read(~/code/**)",
      "Read(~/Downloads/**)",
      "Read(~/Documents/**)",
      "Read(~/tmp/**)",
      "Read(/tmp/**)",
      "Read(~/.ultrabrain/**)",
      "Write(~/.ultrabrain/**)",
      "Edit(~/.ultrabrain/**)",
      "Bash(make:*)",
      "Bash(mvn:*)",
      "Bash(./mvnw:*)",
      "Bash(npm:*)",
      "Bash(bun:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cp:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(openspec:*)",
      "Bash(npx:*)",
      "Bash(python3:*)",
      "Bash(xargs ls:*)",
      "Bash(bc)",
      "Bash(codex:*)",
      "Bash(kubectl:*)",
      "Bash(~/.claude/hooks/*)",
      "Bash(echo:*)",
      "WebSearch",
      "WebFetch",
      "Read(//private/tmp/**)",
      "Skill(planning-with-files)",
      "Skill(commit)",
      "Skill(commit-push)",
      "Skill(commit-push-pr)",
      "Skill(clean-gone-branches)",
      "Skill(claude-api)",
      "Bash(jq:*)",
      "Bash(zsh:*)",
      "Bash(bash:*)",
      "Bash(rtk:*)",
      "Bash(ls:*)",
      "Bash(wait)",
      "Bash(xxd)",
      "Bash(curl:*)"
    ],
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout .:*)",
      "Bash(git restore .:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh release delete:*)",
      "Bash(gh api * -X DELETE)",
      "Bash(gh api * --method DELETE)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/using-git-commit-co-author-tool.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/using-ultrabrain-precompact.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/using-skills.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/using-git-commit-co-author-session.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/using-ultrabrain-session.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "jdtls-lombok-lsp@shihyuho-dotfiles": true,
    "lua-lsp@claude-plugins-official": true,
    "output-styles@shihyuho-dotfiles": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "define@shihyuho-dotfiles": true,
    "agent-skills@addy-agent-skills": true
  },
  "extraKnownMarketplaces": {
    "planning-with-files": {
      "source": {
        "source": "github",
        "repo": "OthmanAdi/planning-with-files"
      },
      "autoUpdate": true
    },
    "shihyuho-dotfiles": {
      "source": {
        "source": "github",
        "repo": "shihyuho/dotfiles"
      },
      "autoUpdate": true
    },
    "addy-agent-skills": {
      "source": {
        "source": "github",
        "repo": "addyosmani/agent-skills"
      }
    }
  },
  "outputStyle": "output-styles:Roast",
  "language": "Traditional Chinese (zh_TW)",
  "effortLevel": "xhigh",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "verbose": true,
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "bypassPermissions": "auto"
}
