# Ghostty Configuration
# https://ghostty.org/docs/config

# Treat left option as Alt/Meta
macos-option-as-alt = left

# Map Command+Left/Right to Home/End
# Try Ctrl+A/E (Emacs-style) which is more universally supported
# These work in most shells and applications including OpenCode
keybind = cmd+left=text:\x01
keybind = cmd+right=text:\x05

# Alternative: If you prefer Home/End sequences, uncomment these instead:
# keybind = cmd+left=text:\x1b[H
# keybind = cmd+right=text:\x1b[F

# Enable system clipboard integration
# Command+C/V for copy/paste (use OSC 52 clipboard passthrough)
clipboard-read = allow
clipboard-write = allow

# Explicitly bind Command+C/V to clipboard actions
# This ensures it works even inside TUI apps like OpenCode
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard

# Let Command+C always copy to system clipboard
copy-on-select = false

# Theme
theme = Material Darker

# Font
font-family = "FiraCode Nerd Font"
font-size = 14
font-thicken = true
adjust-cell-height = 2
font-feature = calt
font-feature = liga

# Window
background-opacity = 0.95
background-blur-radius = 20
macos-titlebar-style = transparent
window-padding-balance = true
window-decoration = true
window-save-state = always
window-theme = auto

# Cursor
cursor-style = bar
cursor-style-blink = true
cursor-opacity = 0.85

# Mouse
mouse-hide-while-typing = true

# Quick terminal
quick-terminal-position = center
quick-terminal-size = 50%
quick-terminal-screen = main
quick-terminal-autohide = true
quick-terminal-animation-duration = 0
quick-terminal-space-behavior = move

# Security
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# Shell integration
shell-integration = zsh

# Tabs
keybind = cmd+t=new_tab
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab
keybind = cmd+w=close_surface

# Splits
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:top
keybind = cmd+alt+down=goto_split:bottom

# Font size
keybind = cmd+plus=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size

# Quick terminal global hotkey
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# Split management
keybind = cmd+shift+e=equalize_splits
keybind = cmd+shift+f=toggle_split_zoom

# Reload config
keybind = cmd+shift+comma=reload_config

# Performance
scrollback-limit = 25000000
